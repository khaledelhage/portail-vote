---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import election from '../../../data/election.json';

export function getStaticPaths() {
  const paths: any[] = [];
  election.postes.forEach(poste => {
    poste.candidats.forEach(candidat => {
      paths.push({
        params: { posteId: poste.id, candidatId: candidat.id },
        props: { poste, candidat },
      });
    });
  });
  return paths;
}

const { poste, candidat } = Astro.props;
---

<BaseLayout title={candidat.nom}>

  <section class="candidat-hero">
    <div class="candidat-hero-inner">
      <a href={`/candidats/${poste.id}`} class="back-link">← {poste.titre}</a>
      <div class="candidat-header">
        <div class="candidat-photo-wrapper">
          <img src={candidat.photo} alt={candidat.nom} class="candidat-photo" />
        </div>
        <div class="candidat-meta">
          <span class="badge">{poste.titre}</span>
          <h1>{candidat.nom}</h1>
          <p class="candidat-titre">{candidat.titre}</p>

          {(candidat.reseaux.facebook || candidat.reseaux.linkedin) && (
            <div class="candidat-reseaux">
              {candidat.reseaux.facebook && (
                <a href={candidat.reseaux.facebook} target="_blank" rel="noopener" aria-label="Facebook">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {candidat.reseaux.linkedin && (
                <a href={candidat.reseaux.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container candidat-content">
      <Fragment set:html={candidat.contenu} />

      {candidat.video && (
        <div class="candidat-video">
          <h3>Vidéo de présentation</h3>
          <div class="video-wrapper">
            <iframe
              src={candidat.video}
              title={`Vidéo de ${candidat.nom}`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container cta-bottom">
      <a href={`/candidats/${poste.id}`} class="btn btn-outline">← Retour aux candidats</a>
      <a href="/bulletin" class="btn btn-primary">Passer au vote</a>
    </div>
  </section>

</BaseLayout>

<style>
  .candidat-hero {
    background: var(--color-bg-dark);
    padding: 6rem 1.5rem 3.5rem;
  }

  .candidat-hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: var(--color-text-on-dark);
    opacity: 0.6;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .back-link:hover {
    opacity: 1;
    color: var(--color-text-on-dark);
  }

  .candidat-header {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .candidat-photo-wrapper {
    flex-shrink: 0;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid rgba(255, 255, 255, 0.15);
  }

  .candidat-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .candidat-meta .badge {
    margin-bottom: 0.75rem;
  }

  .candidat-meta h1 {
    color: var(--color-text-on-dark);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .candidat-titre {
    color: var(--color-text-on-dark);
    opacity: 0.75;
    font-size: 1.1rem;
  }

  .candidat-reseaux {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .candidat-reseaux a {
    color: var(--color-text-on-dark);
    opacity: 0.6;
    transition: opacity var(--transition);
  }

  .candidat-reseaux a:hover {
    opacity: 1;
  }

  /* CONTENU */
  .candidat-content {
    max-width: 720px;
  }

  .candidat-content :global(h3) {
    font-size: 1.3rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-heading);
  }

  .candidat-content :global(h3:first-child) {
    margin-top: 0;
  }

  .candidat-content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  .candidat-content :global(ul) {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }

  .candidat-content :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .candidat-video {
    margin-top: 3rem;
  }

  .candidat-video h3 {
    margin-bottom: 1rem;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .cta-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .candidat-hero {
      padding: 5rem 1.25rem 2.5rem;
    }

    .candidat-header {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .candidat-photo-wrapper {
      width: 120px;
      height: 120px;
    }

    .candidat-meta h1 {
      font-size: 1.6rem;
    }

    .candidat-reseaux {
      justify-content: center;
    }

    .cta-bottom {
      flex-direction: column;
    }

    .cta-bottom .btn {
      width: 100%;
    }
  }
</style>
