---
import BaseLayout from '../../layouts/BaseLayout.astro';
import election from '../../data/election.json';

export function getStaticPaths() {
  return election.postes.map(poste => ({
    params: { id: poste.id },
    props: { poste },
  }));
}

const { poste } = Astro.props;
---

<BaseLayout title={poste.titre}>

  <section class="page-header">
    <div class="container">
      <a href="/candidats" class="back-link">← Tous les postes</a>
      <h1>{poste.titre}</h1>
      <p>{poste.description}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="candidats-grid">
        {poste.candidats.map(candidat => (
          <a href={`/candidats/${poste.id}/${candidat.id}`} class="candidat-card card">
            <div class="candidat-photo">
              <img src={candidat.photo} alt={candidat.nom} />
            </div>
            <div class="candidat-info">
              <h3>{candidat.nom}</h3>
              <p class="candidat-titre">{candidat.titre}</p>
              <p class="candidat-presentation">{candidat.presentation}</p>
              <span class="candidat-link">Voir le profil complet →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="page-cta">
        <a href="/bulletin" class="btn btn-primary btn-lg">Passer au vote</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background: var(--color-bg-dark);
    padding: 6rem 1.5rem 3rem;
    text-align: center;
  }

  .page-header h1 {
    color: var(--color-text-on-dark);
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-on-dark);
    opacity: 0.8;
    font-size: 1.05rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-text-on-dark);
    opacity: 0.6;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .back-link:hover {
    opacity: 1;
    color: var(--color-text-on-dark);
  }

  .candidats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 1.5rem;
  }

  .candidat-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-soft), transform var(--transition-soft);
  }

  .candidat-card:hover {
    color: inherit;
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .candidat-photo {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .candidat-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .candidat-info {
    flex: 1;
  }

  .candidat-info h3 {
    font-size: 1.15rem;
    margin-bottom: 0.15rem;
  }

  .candidat-titre {
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .candidat-presentation {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .candidat-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .page-cta {
    text-align: center;
    margin-top: 3rem;
  }

  @media (max-width: 768px) {
    .candidats-grid {
      grid-template-columns: 1fr;
    }

    .candidat-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .page-header {
      padding: 5rem 1.25rem 2.5rem;
    }
  }
</style>
